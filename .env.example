# Public site URL used for metadata, sitemap and canonical URLs.
NEXT_PUBLIC_SITE_URL=https://www.atleticoxeneizes149.com

# Sanity CMS public identifiers.
NEXT_PUBLIC_SANITY_PROJECT_ID=pp933t0a
NEXT_PUBLIC_SANITY_DATASET=production

# Server-only Sanity read token.
# Do not expose this with NEXT_PUBLIC_.
# Required on Hostinger if the Sanity dataset is private.
SANITY_API_READ_TOKEN=

# Sanity write/editor token for local sync scripts only.
# Use only when running: npm run sanity:sync
# Never commit real token values.
SANITY_AUTH_TOKEN=

# Supabase is parked for advanced future features.
# Keep these empty unless /admin is intentionally reactivated.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
